@page "/run"
@rendermode InteractiveServer
@inject AppSession Session
@inject EngineRunner Runner
@inject NavigationManager Nav

<PageTitle>Run — Aran</PageTitle>

<h2>④ Run Shielding Calculation</h2>

@if (!Session.InputConfirmed)
{
    <div class="alert alert-warning">Input step not completed. <a href="/input">Go to Input ›</a></div>
    return;
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@if (!Session.RunCompleted)
{
    <button class="btn btn-primary mb-3" @onclick="DoRun" disabled="@_running">
        @if (_running)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            <span>Calculating…</span>
        }
        else
        {
            <span>&#9654; Run calculations</span>
        }
    </button>
}
else
{
    <div class="alert alert-success mb-3">Calculations complete. <a href="/download">Go to Download ›</a></div>
}

@if (Session.NcrpWallResult is not null)
{
    <h5 class="mt-3">NCRP 151 — Wall results</h5>
    @ResultTable(Session.NcrpWallResult)
}

@if (Session.AerbWallResult is not null)
{
    <h5 class="mt-3">AERB — Wall results</h5>
    @ResultTable(Session.AerbWallResult)
}

@if (Session.NcrpDoorResult is not null)
{
    <h5 class="mt-3">NCRP 151 — Door</h5>
    @DoorTable(Session.NcrpDoorResult)
}

@if (Session.AerbDoorResult is not null)
{
    <h5 class="mt-3">AERB — Door</h5>
    @DoorTable(Session.AerbDoorResult)
}

<div class="mt-3">
    <a href="/input" class="btn btn-outline-secondary me-2">‹ Back</a>
    @if (Session.RunCompleted)
    {
        <a href="/download" class="btn btn-primary">Download reports ›</a>
    }
</div>

@code {
    private bool _running;
    private string? _error;

    private async Task DoRun()
    {
        _running = true;
        _error = null;
        try
        {
            await Task.Run(() => Runner.Run(Session));
        }
        catch (Exception ex)
        {
            _error = "Calculation failed: " + ex.Message;
        }
        finally
        {
            _running = false;
        }
    }

    private RenderFragment ResultTable(Aran.Engines.Linac.LinacShieldingResult result) => __builder =>
    {
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "class", "table-responsive mb-2");
        __builder.OpenElement(2, "table");
        __builder.AddAttribute(3, "class", "table table-sm table-bordered small");
        __builder.OpenElement(4, "thead");
        __builder.AddMarkupContent(5,
            "<tr class='table-dark'><th>Barrier</th><th>Role</th><th>Required (mm)</th><th>Provided (mm)</th><th>Result</th></tr>");
        __builder.CloseElement();
        __builder.OpenElement(6, "tbody");
        foreach (var b in result.Barriers)
        {
            string rowClass = b.Passes ? "table-success" : "table-danger";
            __builder.OpenElement(7, "tr");
            __builder.AddAttribute(8, "class", rowClass);
            __builder.AddMarkupContent(9,
                $"<td>{b.BarrierId}</td><td>{b.Role}</td>" +
                $"<td class='text-end'>{b.RequiredThicknessMm:0.#}</td>" +
                $"<td class='text-end'>{b.ProvidedThicknessMm:0.#}</td>" +
                $"<td class='fw-bold'>{(b.Passes ? "PASS" : "FAIL")}</td>");
            __builder.CloseElement();
        }

        __builder.CloseElement();
        __builder.CloseElement();
        __builder.CloseElement();
    };

    private RenderFragment DoorTable(Aran.Engines.Linac.DoorEvaluation door) => __builder =>
    {
        string cls = door.BarePasses ? "alert-success" : "alert-warning";
        string txt = door.BarePasses ? "BARE DOOR PASSES" : "BARE DOOR FAILS — shielding required";
        __builder.AddMarkupContent(0,
            $"<div class='alert {cls} small mb-1'>{txt} — " +
            $"{door.BareDoseSvPerWeek * 1e6:0.##} µSv/wk vs " +
            $"{door.DesignGoalSvPerWeek * 1e6:0.##} µSv/wk limit</div>");
    };
}
